Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "Constants", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"n", "=", "1000"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"observe", "=", "0.1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"k", "=", "10"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SeedRandom", "[", "123", "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Set", " ", "the", " ", "scaling", " ", "factor", " ", "as", " ", 
     "desired"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"scale", "=", "1"}], ";"}], " ", "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Generate", " ", "w", " ", "as", " ", "a", " ", "vector", " ", 
     "according", " ", "to", " ", "the", " ", "inc_weights", " ", 
     "function"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"w", "=", 
     RowBox[{"Array", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"#", "^", "scale"}], "/", "n"}], "&"}], ",", "n"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Calculate", " ", "the", " ", "number", " ", "of", " ", "observations", 
     " ", "to", " ", "sample"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"numObservations", "=", 
     RowBox[{"Round", "[", 
      RowBox[{"n", "*", "observe"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Perform", " ", "weighted", " ", "sampling", " ", "without", " ", 
     "replacement"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Obs", "=", 
     RowBox[{"RandomSample", "[", 
      RowBox[{
       RowBox[{"w", "->", 
        RowBox[{"Thread", "[", 
         RowBox[{
          RowBox[{"Range", "[", "n", "]"}], "->", "w"}], "]"}]}], ",", 
       "numObservations"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Full", " ", "list", " ", "of", " ", "pairs"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fullPairs", "=", 
     RowBox[{"Thread", "[", 
      RowBox[{
       RowBox[{"Range", "[", "n", "]"}], "->", "w"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Remaining", " ", "pairs", " ", "after", " ", "excluding", " ", "Obs"}], 
    "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Mis", "=", 
     RowBox[{"Complement", "[", 
      RowBox[{"fullPairs", ",", "Obs"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"delta", "=", 
     RowBox[{"Total", "[", 
      RowBox[{"Mis", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Define", " ", "z", 
     RowBox[{"(", "h", ")"}], " ", "function"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"z", "[", "h_", "]"}], ":=", 
     RowBox[{"delta", "-", 
      RowBox[{"1", "/", "h"}], "-", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"w", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", "^", 
            RowBox[{"(", 
             RowBox[{"h", "*", 
              RowBox[{"w", "[", 
               RowBox[{"[", "i", "]"}], "]"}]}], ")"}]}], "-", "1"}], ")"}]}],
         ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"Obs", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "1"}], "]"}], "]"}]}], "}"}]}], "]"}]}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{
      "Find", " ", "h", " ", "using", " ", "FindRoot", " ", "with", " ", 
       "the", " ", "Newton"}], "-", 
      RowBox[{"Raphson", " ", "method"}]}], ",", 
     RowBox[{
     "starting", " ", "with", " ", "an", " ", "initial", " ", "guess"}]}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"hSolution", "=", 
     RowBox[{"FindRoot", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"z", "[", "h", "]"}], "==", "0"}], ",", 
       RowBox[{"{", 
        RowBox[{"h", ",", 
         RowBox[{"1", "/", "delta"}]}], "}"}], ",", 
       RowBox[{"Method", "->", "\"\<Newton\>\""}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Extract", " ", "the", " ", "value", " ", "of", " ", "h", " ", "from", 
     " ", "the", " ", "solution"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"h", "=", 
     RowBox[{"h", "/.", " ", "hSolution"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Define", " ", "Phi", " ", "function"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Phi", "[", "tau_", "]"}], ":=", 
     RowBox[{"h", "*", "delta", "*", 
      RowBox[{"tau", "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"h", "*", "delta"}], "-", "1"}], ")"}]}], "*", 
      RowBox[{"Product", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"tau", "^", 
           RowBox[{"(", 
            RowBox[{"h", "*", 
             RowBox[{"w", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], ")"}]}]}], ")"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"Obs", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "1"}], "]"}], "]"}]}], "}"}]}], "]"}]}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Randomly", " ", "select", " ", "k", " ", "threads", " ", "from", " ", 
     "Obs", " ", "and", " ", "Mis", " ", "each"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"selectedObs", "=", 
     RowBox[{"RandomSample", "[", 
      RowBox[{"Obs", ",", "k"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"selectedMis", "=", 
     RowBox[{"RandomSample", "[", 
      RowBox[{"Mis", ",", "k"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "selectedObs", "\[IndentingNewLine]", "selectedMis", "\[IndentingNewLine]", 
   RowBox[{"di", " ", "=", " ", 
    RowBox[{
     RowBox[{"Total", "[", 
      RowBox[{"selectedObs", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}], "-", 
     RowBox[{"Total", "[", 
      RowBox[{"selectedMis", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}]}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eta", "[", "tau_", "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{"tau", "^", 
      RowBox[{"(", 
       RowBox[{"h", "*", "di"}], ")"}]}], "*", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"delta", "+", "di"}], ")"}], "/", "delta"}], "*", 
     RowBox[{
      RowBox[{"Product", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"tau", "^", 
           RowBox[{"(", 
            RowBox[{"h", "*", 
             RowBox[{"w", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], ")"}]}]}], ")"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"selectedMis", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "1"}], "]"}], "]"}]}], "}"}]}], "]"}], "/", 
      RowBox[{"Product", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"tau", "^", 
           RowBox[{"(", 
            RowBox[{"h", "*", 
             RowBox[{"w", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], ")"}]}]}], ")"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"selectedObs", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "1"}], "]"}], "]"}]}], "}"}]}], "]"}]}]}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Plot", " ", "Phi", " ", "function", " ", "with", " ", "its", " ", "own", 
     " ", "scale", " ", "on", " ", "the", " ", "left"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"phiPlot", "=", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"Phi", "[", "tau", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"tau", ",", "0", ",", "1"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", "Blue"}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<\[Tau]\>\"", ",", "None"}], "}"}]}], ",", 
       RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Plot", " ", "eta", " ", "function", " ", "with", " ", "its", " ", "own",
       " ", "scale"}], ",", 
     RowBox[{
     "invisible", " ", "for", " ", "now", " ", "to", " ", "determine", " ", 
      "range"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"etaPlot", "=", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"eta", "[", "tau", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"tau", ",", "0", ",", "1"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", "Red"}], ",", 
       RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Extract", " ", "plot", " ", "ranges", " ", "to", " ", "find", " ", 
     "scaling", " ", "factor"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"phiPlotRange", "=", 
     RowBox[{
      RowBox[{"AbsoluteOptions", "[", 
       RowBox[{"phiPlot", ",", "PlotRange"}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", "2", ",", "2"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"etaPlotRange", "=", 
     RowBox[{
      RowBox[{"AbsoluteOptions", "[", 
       RowBox[{"etaPlot", ",", "PlotRange"}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", "2", ",", "2"}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Scale", " ", "factor", " ", "to", " ", "match", " ", 
     RowBox[{"eta", "'"}], "s", " ", "range", " ", "to", " ", 
     RowBox[{"phi", "'"}], "s", " ", "for", " ", "visual", " ", 
     "consistency"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"scaleFactor", "=", 
     RowBox[{
      RowBox[{"phiPlotRange", "[", 
       RowBox[{"[", "2", "]"}], "]"}], "/", 
      RowBox[{"etaPlotRange", "[", 
       RowBox[{"[", "2", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Manually", " ", "create", " ", "ticks", " ", "for", " ", "the", " ", 
      "right", " ", "y"}], "-", 
     RowBox[{"axis", " ", "corresponding", " ", "to", " ", 
      RowBox[{"eta", "'"}], "s", " ", "values"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rightAxisTicks", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"i", ",", 
         RowBox[{"NumberForm", "[", 
          RowBox[{
           RowBox[{"i", "/", "scaleFactor"}], ",", 
           RowBox[{"{", 
            RowBox[{"5", ",", "2"}], "}"}]}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "0", ",", 
         RowBox[{"phiPlotRange", "[", 
          RowBox[{"[", "2", "]"}], "]"}], ",", 
         RowBox[{
          RowBox[{"phiPlotRange", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "/", "10"}]}], "}"}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Plot", " ", "eta", " ", "adjusted", " ", "for", " ", "combined", " ", 
      "plot"}], ",", 
     RowBox[{
     "without", " ", "affecting", " ", "its", " ", "scale", " ", "for", " ", 
      "ticks"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"etaPlotAdjusted", "=", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"eta", "[", "tau", "]"}], "*", "scaleFactor"}], ",", 
       RowBox[{"{", 
        RowBox[{"tau", ",", "0", ",", "1"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", "Red"}], ",", 
       RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Combine", " ", "the", " ", "plots", " ", "with", " ", "manual", " ", 
